---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <!-- Background Container -->
  <main id="main_container" class="min-h-screen bg-white flex flex-col items-center justify-center p-4 relative overflow-hidden transition-colors duration-1000">
    
    <!-- Circular Reveal Element -->
    <div id="circle_reveal" class="fixed top-1/2 left-1/2 w-4 h-4 bg-black rounded-full -translate-x-1/2 -translate-y-1/2 scale-0 z-10 pointer-events-none transition-transform duration-1000 ease-in-out"></div>

    <!-- Loading Animation -->
    <div id="loading_screen" class="flex flex-col items-center text-center z-20 transition-opacity duration-300">
      <div class="text-7xl mb-6 animate-bounce">⏳</div>
      <h2 class="text-4xl md:text-5xl font-black tracking-tight text-gray-900 mb-4 animate-pulse">
        Sorteando...
      </h2>
      <p class="text-xl text-gray-500 font-medium h-8 overflow-hidden relative w-64 text-center" id="shuffling_names">
        <!-- Names will flash here -->
      </p>
    </div>

    <!-- Results Container (Hidden initially) -->
    <div id="results_screen" class="hidden w-full max-w-3xl z-20 animate-fade-in-up">
      <div class="text-center mb-10">
        <span class="text-6xl mb-4 block">🎉</span>
        <h1 class="text-5xl md:text-6xl font-black tracking-tight text-white drop-shadow-sm leading-tight">
          ¡Sorteo Finalizado!
        </h1>
        <p class="text-gray-300 mt-2 font-medium text-lg">Aquí están los resultados oficiales.</p>
      </div>

      <div class="bg-black border border-gray-800 rounded-[3rem] p-8 md:p-12 shadow-2xl flex flex-col gap-10">
        
        <!-- Winners -->
        <div>
          <h2 class="text-3xl font-black text-white mb-6 flex items-center gap-3">
            <span class="text-4xl">🏆</span> Ganadores
          </h2>
          <div id="winners_list" class="flex flex-col gap-4">
            <!-- Injected via JS -->
          </div>
        </div>

        <!-- Substitutes (if any) -->
        <div id="substitutes_section" class="hidden">
           <hr class="border-gray-800 mb-10" />
           <h2 class="text-2xl font-black text-white mb-6 flex items-center gap-3">
            <span class="text-3xl">🥈</span> Suplentes
          </h2>
          <div id="substitutes_list" class="flex flex-col gap-3">
            <!-- Injected via JS -->
          </div>
        </div>

      </div>
      
      <div class="mt-10 flex flex-col md:flex-row items-center justify-center gap-4">
        <button onclick="window.print()" class="bg-gray-800 text-white font-bold px-8 py-4 rounded-full shadow hover:bg-gray-700 transition-colors flex items-center gap-2 border border-gray-700">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z"></path></svg>
          Guardar Certificado
        </button>
        <a href="/" class="bg-white text-black font-bold px-8 py-4 rounded-full shadow hover:bg-gray-200 transition-colors">
          Hacer otro sorteo
        </a>
      </div>
    </div>
  </main>
</Layout>

<script>
  import { getMockComments } from '../data/mock';

  // Extract search params
  const urlParams = new URLSearchParams(window.location.search);
  const postId = urlParams.get('post') || 'demo_post';
  const numWinners = parseInt(urlParams.get('winners') || '1');
  const numSubstitutes = parseInt(urlParams.get('substitutes') || '0');
  const filterDuplicates = urlParams.get('filter_duplicates') === '1';
  const filterMentions = urlParams.get('filter_mentions') === '1';
  const mentionsCount = parseInt(urlParams.get('mentions_count') || '1');

  // Generate mock comments
  let comments = getMockComments(postId, 500);

  // Apply filters
  if (filterMentions) {
    comments = comments.filter(c => c.mentions.length >= mentionsCount);
  }
  if (filterDuplicates) {
    const unique = new Map();
    comments.forEach(c => {
      if (!unique.has(c.username)) {
        unique.set(c.username, c);
      }
    });
    comments = Array.from(unique.values());
  }

  const totalNeeded = numWinners + numSubstitutes;
  if (comments.length < totalNeeded) {
    while (comments.length < totalNeeded) {
      comments.push({...comments[0], id: Math.random().toString()});
    }
  }

  // Shuffle
  const shuffled = [...comments].sort(() => 0.5 - Math.random());
  const winners = shuffled.slice(0, numWinners);
  const substitutes = shuffled.slice(numWinners, numWinners + numSubstitutes);

  // Shuffling animation effect
  const shufflingNamesEl = document.getElementById('shuffling_names');
  let shuffleInterval;
  
  if (shufflingNamesEl) {
    let i = 0;
    shuffleInterval = setInterval(() => {
      shufflingNamesEl.innerText = '@' + comments[i % comments.length]?.username || 'usuario';
      i++;
    }, 50);
  }

  // Circular reveal logic
  setTimeout(() => {
    if (shuffleInterval) clearInterval(shuffleInterval);
    
    const loadingScreen = document.getElementById('loading_screen');
    const circle = document.getElementById('circle_reveal');
    const mainContainer = document.getElementById('main_container');
    const resultsScreen = document.getElementById('results_screen');

    // 1. Hide text of loading screen softly
    loadingScreen.style.opacity = '0';
    
    setTimeout(() => {
      loadingScreen.classList.add('hidden');
      
      // 2. Expand the circle
      // Calculate max dimension needed to cover the screen
      const maxDim = Math.max(window.innerWidth, window.innerHeight);
      // We start at 16px (w-4). So to cover 2x maxDim we need a scale around (2*maxDim)/16
      const scaleNeeded = (maxDim * 2.5) / 16;
      circle.style.transform = `translate(-50%, -50%) scale(${scaleNeeded})`;
      
      // 3. Wait for circle animation, then set background and show results
      setTimeout(() => {
        mainContainer.classList.remove('bg-white');
        mainContainer.classList.add('bg-black');
        circle.style.display = 'none'; // hide it after we swap bg
        
        resultsScreen.classList.remove('hidden');

        // Render Winners (Dark Theme)
        const winnersList = document.getElementById('winners_list');
        if (winnersList) {
          winnersList.innerHTML = winners.map((w, i) => `
            <div class="flex items-center gap-4 bg-gray-900 border border-gray-800 p-4 rounded-2xl animate-fade-in-up" style="animation-delay: ${i * 150}ms">
              <div class="w-12 h-12 rounded-full bg-white flex items-center justify-center font-black text-black shrink-0">
                ${i + 1}
              </div>
              <div class="flex-1 overflow-hidden">
                <p class="font-bold text-white text-lg truncate">@${w.username}</p>
                <p class="text-sm text-gray-400 truncate" title="${w.text}">${w.text}</p>
              </div>
            </div>
          `).join('');
        }

        // Render Substitutes (Dark Theme)
        if (substitutes.length > 0) {
          document.getElementById('substitutes_section')?.classList.remove('hidden');
          const subList = document.getElementById('substitutes_list');
          if (subList) {
            subList.innerHTML = substitutes.map((s, i) => `
              <div class="flex items-center gap-4 bg-gray-900 border border-gray-800 p-3 rounded-xl animate-fade-in-up" style="animation-delay: ${(winners.length + i) * 150}ms">
                <div class="w-10 h-10 rounded-full bg-gray-800 flex items-center justify-center font-bold text-gray-400 text-sm shrink-0">
                  ${i + 1}
                </div>
                <div class="flex-1 overflow-hidden">
                  <p class="font-bold text-gray-300 truncate">@${s.username}</p>
                </div>
              </div>
            `).join('');
          }
        }
      }, 1000); // Wait 1s for the circle to finish growing
    }, 300); // Short delay after fading out loading screen
    
  }, 3000); // 3 seconds of loading

</script>

<style>
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  .animate-fade-in-up {
    animation: fadeInUp 0.6s ease-out forwards;
    opacity: 0;
  }
</style>
